@page "/"
@using ALGarage.Web.Components.Shared
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["AppName"]</PageTitle>

<div class="page-head">
    <h1>@L["AppName"]</h1>
</div>

<p>Acompanhe a saúde do seu Volvo: cadastre pelo VIN e veja a manutenção prevista por tempo e por km/dia.</p>

<AuthorizeView>
    <Authorized>
        <a class="btn" href="/garagem">Ir para a garagem</a>
    </Authorized>
    <NotAuthorized>
        <p>
            <a class="btn" href="/account/register">Criar conta</a>
            &nbsp;
            <a href="/account/login">Entrar</a>
        </p>
    </NotAuthorized>
</AuthorizeView>

<p style="color:var(--text-muted)">
    MVP (Fase 1) — catálogo curado: <strong>Volvo V40 (2012–2019)</strong>. Idiomas: en · pt-BR. Tema padrão: dark.
</p>
